# Copy this file to .env and fill in your values

# Database connection URL
# SQLite for local development (default):
DATABASE_URL=sqlite:///./xaminator.db
# MySQL for production:
# DATABASE_URL=mysql+pymysql://root:password@localhost/xaminator_db

# JWT authentication settings
SECRET_KEY=your-super-secret-key-change-in-production-must-be-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Default admin password (only used when creating initial admin user)
DEFAULT_ADMIN_PASSWORD=admin123

# CORS settings (comma-separated list of allowed origins)
# For production, set this to your actual frontend domain(s)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500

# Set to "true" to allow all origins (development only, not recommended for production)
CORS_ALLOW_ALL=false
